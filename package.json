{
  "name": "tree-sitter-batch",
  "version": "0.10.1",
  "description": "A Windows Batch/CMD grammar for tree-sitter",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wharflab/tree-sitter-batch.git"
  },
  "license": "MIT",
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "batch",
    "cmd",
    "bat"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "!bindings/node/*_test.js",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "dependencies": {
    "node-addon-api": "^8.5.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "eslint-config-treesitter": "^1.0.2",
    "globals": "^17.5.0",
    "prebuildify": "^6.0.1",
    "tree-sitter-cli": "0.26.8",
    "tree-sitter-go-types": "^0.1.0"
  },
  "overrides": {
    "eslint-plugin-jsdoc": "^62.9.0"
  },
  "peerDependencies": {
    "tree-sitter": ">=0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "generate": "tree-sitter generate --abi 14 && tree-sitter-go-types",
    "lint": "eslint grammar.js",
    "test": "node --test bindings/node/*_test.js"
  }
}
