{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "batch",
      "camelcase": "Batch",
      "scope": "source.batchfile",
      "path": ".",
      "file-types": [
        "bat",
        "cmd"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injection-regex": "^(bat|batch|cmd)$"
    }
  ],
  "metadata": {
    "version": "0.3.0",
    "license": "MIT",
    "description": "A Windows Batch/CMD grammar for tree-sitter",
    "authors": [
      {
        "name": "WharfLab"
      }
    ],
    "links": {
      "repository": "https://github.com/wharflab/tree-sitter-batch"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
